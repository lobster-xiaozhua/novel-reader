#!/bin/bash

# Novel Reader 统一部署入口
# 自动检测平台并选择合适的部署方式
# 版本: 1.0.0

set -euo pipefail

SCRIPT_VERSION="1.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

print_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
print_success() { echo -e "${GREEN}[OK]${NC} $1"; }
print_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
print_error() { echo -e "${RED}[ERROR]${NC} $1"; }
print_step() { echo -e "${CYAN}[>]${NC} $1"; }

print_banner() {
    echo ""
    echo -e "${MAGENTA}╔════════════════════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}║  Novel Reader 统一部署工具 v${SCRIPT_VERSION}            ║${NC}"
    echo -e "${MAGENTA}╚════════════════════════════════════════════════════╝${NC}"
    echo ""
}

detect_platform() {
    local os_type="unknown"
    local platform="unknown"

    if [ -n "${TERMUX_VERSION:-}" ]; then
        platform="termux"
        os_type="termux"
    elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
        if [ -f /etc/os-release ]; then
            . /etc/os-release
            case "$ID" in
                ubuntu|debian|linuxmint|elementary)
                    os_type="debian"
                    ;;
                fedora|rhel|centos|rocky|alma)
                    os_type="rhel"
                    ;;
                arch|manjaro|endeavouros)
                    os_type="arch"
                    ;;
                alpine)
                    os_type="alpine"
                    ;;
                *)
                    os_type="linux"
                    ;;
            esac
        fi

        if command -v wsl.exe &>/dev/null || grep -qi "microsoft" /proc/version 2>/dev/null; then
            platform="wsl"
        else
            platform="linux"
        fi
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        platform="macos"
        os_type="macos"
    elif [[ "$OSTYPE" == "cygwin" ]] || [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "win32" ]]; then
        platform="windows"
        os_type="windows"
    else
        platform="unknown"
    fi

    echo "$platform:$os_type"
}

show_platform_info() {
    local platform_info=$(detect_platform)
    local platform="${platform_info%%:*}"
    local os_type="${platform_info##*:}"

    print_step "平台检测结果:"
    echo "  平台: $platform"
    echo "  系统: $os_type"
    echo "  OS: $OSTYPE"
    echo ""
}

run_windows() {
    if [[ "$OSTYPE" == "cygwin" ]] || [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "win32" ]]; then
        print_step "使用 Windows PowerShell 部署..."
        if command -v powershell.exe &>/dev/null; then
            powershell.exe -ExecutionPolicy Bypass -File "$SCRIPT_DIR/deploy.ps1" "$@"
        elif command -v pwsh &>/dev/null; then
            pwsh -ExecutionPolicy Bypass -File "$SCRIPT_DIR/deploy.ps1" "$@"
        else
            print_error "Windows 环境下需要 PowerShell，请安装 PowerShell 7+"
            exit 1
        fi
    else
        print_error "非 Windows 环境，无法使用 Windows 部署"
        exit 1
    fi
}

run_linux() {
    print_step "使用 Linux 部署脚本..."
    bash "$SCRIPT_DIR/deploy.sh" "$@"
}

run_termux() {
    print_step "使用 Termux 部署脚本..."
    bash "$SCRIPT_DIR/deploy-termux.sh" "$@"
}

show_help() {
    print_banner
    cat << EOF
Novel Reader 统一部署工具

用法: ./deploy [command]

命令:
  install     安装所有依赖
  start       启动服务
  stop        停止服务
  restart     重启服务
  status      查看服务状态
  logs        查看日志
  deps        仅安装依赖
  detect      显示平台信息
  help        显示帮助

平台:
  Windows (PowerShell): .\deploy.ps1
  Linux/macOS: ./deploy.sh
  Termux: ./deploy-termux.sh

自动检测:
  本脚本会自动检测当前平台并调用相应的部署脚本

文档: https://github.com/lobster-xiaozhua/novel-reader
EOF
}

main() {
    if [ $# -eq 0 ]; then
        print_banner
        show_platform_info

        local platform_info=$(detect_platform)
        local platform="${platform_info%%:*}"

        case "$platform" in
            windows)
                print_info "检测到 Windows 环境"
                run_windows
                ;;
            wsl)
                print_info "检测到 WSL 环境，使用 Linux 脚本"
                run_linux
                ;;
            termux)
                print_info "检测到 Termux 环境"
                run_termux
                ;;
            linux|macos)
                print_info "检测到 $platform 环境"
                run_linux
                ;;
            *)
                print_error "无法识别的平台: $platform"
                show_help
                exit 1
                ;;
        esac
    else
        case "${1:-}" in
            detect)
                print_banner
                show_platform_info
                ;;
            help|--help|-h)
                show_help
                ;;
            *)
                local platform_info=$(detect_platform)
                local platform="${platform_info%%:*}"

                case "$platform" in
                    windows)
                        run_windows "$@"
                        ;;
                    wsl)
                        run_linux "$@"
                        ;;
                    termux)
                        run_termux "$@"
                        ;;
                    linux|macos)
                        run_linux "$@"
                        ;;
                    *)
                        print_error "无法识别的平台"
                        exit 1
                        ;;
                esac
                ;;
        esac
    fi
}

main "$@"
