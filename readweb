#!/bin/bash
# readweb - Novel Reader 项目管理命令行工具
# 用法: bash readweb <command> [options]  或  ./readweb <command>（需执行权限）
#
# 命令:
#   bash readweb start [--docker]  - 启动项目（默认 local 模式）
#   bash readweb stop              - 停止服务
#   bash readweb restart          - 重启服务
#   bash readweb update           - 更新项目
#   bash readweb status           - 查看服务状态
#   bash readweb logs             - 查看日志
#   bash readweb deps             - 安装/更新依赖
#   bash readweb mirror           - 配置镜像源
#   bash readweb clean            - 清理环境
#   bash readweb doctor           - 环境检查
#   bash readweb backup           - 备份数据
#   bash readweb restore          - 恢复数据
#   bash readweb version          - 显示版本信息
#   bash readweb help             - 显示帮助

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_NAME="novel-reader"
PROJECT_DIR="${READWEB_PROJECT_DIR:-$SCRIPT_DIR}"
VERSION="1.0.0"
RUN_MODE="${READWEB_MODE:-local}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[✓]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[⚠]${NC} $1"; }
log_error() { echo -e "${RED}[✗]${NC} $1"; }
log_step() { echo -e "${CYAN}[→]${NC} $1"; }

print_banner() {
    echo ""
    echo -e "${MAGENTA}╔═══════════════════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}║${NC}  ${CYAN}Novel Reader - 项目管理工具${NC}                      ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}║${NC}  ${CYAN}版本: $VERSION${NC}  模式: $([ "$RUN_MODE" = "docker" ] && echo "${GREEN}Docker${NC}" || echo "${YELLOW}Local${NC}")                    ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}╚═══════════════════════════════════════════════════╝${NC}"
    echo ""
}

show_help() {
    print_banner
    cat << EOF
用法: bash readweb <command> [options]

命令:
  ${GREEN}start${NC} [--docker]    启动项目（默认 local 模式）
  ${GREEN}stop${NC}                 停止服务
  ${GREEN}restart${NC}              重启服务
  ${GREEN}update${NC}               更新项目
  ${GREEN}status${NC}               查看服务状态
  ${GREEN}logs${NC}                 查看日志（可指定服务）
  ${GREEN}deps${NC}                 安装/更新依赖
  ${GREEN}mirror${NC}               配置镜像源
  ${GREEN}clean${NC}                清理环境（可选：--all）
  ${GREEN}doctor${NC}               环境检查
  ${GREEN}backup${NC}               备份数据
  ${GREEN}restore${NC}              恢复数据（需指定备份文件）
  ${GREEN}version${NC}              显示版本信息
  ${GREEN}help${NC}                 显示此帮助

模式说明:
  ${YELLOW}local${NC}  (默认)  直接使用本地 Python/Node.js 启动服务
  ${GREEN}docker${NC}         使用 Docker Compose 启动服务

示例:
  bash readweb start          # 本地模式启动（推荐）
  bash readweb start --docker # Docker 模式启动
  bash readweb update         # 更新项目
  bash readweb logs backend   # 查看后端日志
  bash readweb doctor         # 检查环境

快捷方式（需执行权限）:
  ./readweb start             # 启动项目
  ./readweb update            # 更新项目

环境变量:
  READWEB_MODE=local|docker    设置默认模式
  READWEB_PROJECT_DIR         设置项目目录
  READWEB_NO_MIRROR           跳过镜像配置
  READWEB_NO_BUILD            跳过构建步骤

更多信息: https://github.com/lobster-xiaozhua/novel-reader
EOF
}

show_version() {
    echo "Novel Reader 项目管理工具 v$VERSION"
    echo ""
    echo "项目目录: $PROJECT_DIR"
    echo "运行模式: $RUN_MODE"
    echo "Node.js: $(node --version 2>/dev/null || echo '未安装')"
    echo "Python: $(python3 --version 2>/dev/null || echo '未安装')"
    echo "Docker: $(docker --version 2>/dev/null || echo '未安装')"
}

check_local_env() {
    log_step "检查本地运行环境..."

    local errors=0

    if ! command -v python3 &> /dev/null; then
        log_error "Python3 未安装"
        ((errors++))
    else
        log_success "Python: $(python3 --version | cut -d' ' -f2)"
    fi

    if ! command -v node &> /dev/null; then
        log_error "Node.js 未安装"
        ((errors++))
    else
        log_success "Node.js: $(node --version)"
    fi

    if ! command -v npm &> /dev/null; then
        log_warning "npm 未安装"
    else
        log_success "npm: $(npm --version)"
    fi

    if ! command -v git &> /dev/null; then
        log_warning "Git 未安装"
    else
        log_success "Git: $(git --version | cut -d' ' -f3)"
    fi

    if [ $errors -gt 0 ]; then
        log_error "本地环境检查失败 ($errors 个错误)"
        return 1
    fi

    log_success "本地环境检查通过"
    return 0
}

check_docker_env() {
    log_step "检查 Docker 运行环境..."

    local errors=0

    if ! command -v docker &> /dev/null; then
        log_error "Docker 未安装"
        ((errors++))
    elif ! docker info &> /dev/null; then
        log_error "Docker 未运行"
        ((errors++))
    else
        log_success "Docker: $(docker --version | cut -d' ' -f3 | cut -d',' -f1)"
    fi

    if ! command -v docker-compose &> /dev/null && ! docker compose version &> /dev/null; then
        log_error "Docker Compose 未安装"
        ((errors++))
    else
        log_success "Docker Compose: 已安装"
    fi

    if [ $errors -gt 0 ]; then
        log_error "Docker 环境检查失败 ($errors 个错误)"
        return 1
    fi

    log_success "Docker 环境检查通过"
    return 0
}

check_env() {
    if [ "$RUN_MODE" = "docker" ]; then
        check_docker_env
    else
        check_local_env
    fi
}

setup_mirrors() {
    if [ -n "$READWEB_NO_MIRROR" ]; then
        log_info "跳过镜像配置（READWEB_NO_MIRROR=1）"
        return 0
    fi

    log_step "配置镜像源..."

    local country="global"
    if command -v curl &> /dev/null; then
        country=$(curl -s --max-time 3 "https://ipinfo.io/country" 2>/dev/null || echo "global")
    fi

    if [ "$country" = "CN" ]; then
        log_info "检测到中国地区，配置国内镜像..."

        mkdir -p ~/.pip
        cat > ~/.pip/pip.conf << 'EOF'
[global]
index-url = https://mirrors.aliyun.com/pypi/simple/
timeout = 60
[install]
trusted-host = mirrors.aliyun.com
EOF
        log_success "pip 镜像: 阿里云"

        npm config set registry https://registry.npmmirror.com 2>/dev/null || true
        log_success "npm 镜像: npmmirror.com"

        mkdir -p ~/.docker
        cat > ~/.docker/daemon.json << 'EOF'
{
  "registry-mirrors": [
    "https://docker.1ms.run",
    "https://docker.xuanyuan.me"
  ]
}
EOF
        log_success "Docker 镜像加速: 已配置"
    else
        log_info "使用官方源"
    fi
}

setup_directories() {
    log_step "创建目录结构..."
    mkdir -p data/{books,index,static,logs,cache,backups,versions}
    log_success "目录创建完成"
}

setup_env() {
    if [ ! -f ".env" ]; then
        log_info "创建环境配置文件..."
        cat > .env << EOF
SECRET_KEY=$(openssl rand -hex 32 2>/dev/null || python3 -c "import secrets; print(secrets.token_hex(32))")
DEBUG=false
DATABASE_URL=sqlite+aiosqlite:///data/novel.db
REDIS_URL=redis://localhost:6379
EOF
        log_success ".env 文件已创建"
    fi
}

install_deps() {
    log_step "安装依赖..."

    if [ -f "backend/requirements.txt" ]; then
        log_info "安装 Python 依赖..."
        cd backend
        if [ ! -d "venv" ]; then
            python3 -m venv venv
        fi
        source venv/bin/activate
        pip install --upgrade pip -q
        pip install -r requirements.txt -q
        deactivate
        cd ..
        log_success "Python 依赖安装完成"
    fi

    if [ -f "frontend/package.json" ]; then
        log_info "安装 Node.js 依赖..."
        cd frontend
        npm install
        cd ..
        log_success "Node.js 依赖安装完成"
    fi
}

build_frontend() {
    if [ -n "$READWEB_NO_BUILD" ]; then
        log_info "跳过构建步骤"
        return 0
    fi

    if [ ! -f "frontend/package.json" ]; then
        return 0
    fi

    log_step "构建前端..."
    cd frontend

    if [ ! -d "node_modules" ]; then
        log_info "安装前端依赖..."
        npm install
    fi

    npm run build
    cd ..
    log_success "前端构建完成"
}

start_redis_local() {
    log_step "启动 Redis..."

    if command -v redis-server &> /dev/null; then
        if ! pgrep -x "redis-server" > /dev/null; then
            mkdir -p data/redis
            redis-server --daemonize yes --dir data/redis --port 6379 2>/dev/null || true
            sleep 1
        fi
        if pgrep -x "redis-server" > /dev/null; then
            log_success "Redis 已启动"
        else
            log_warning "Redis 启动失败，继续..."
        fi
    else
        log_warning "Redis 未安装，跳过"
    fi
}

start_backend_local() {
    log_step "启动后端服务..."

    cd backend

    if [ ! -d "venv" ]; then
        python3 -m venv venv
        source venv/bin/activate
        pip install --upgrade pip -q
        pip install -r requirements.txt -q
    else
        source venv/bin/activate
    fi

    if [ -f "uvicorn.pid" ] && kill -0 $(cat uvicorn.pid) 2>/dev/null; then
        log_info "后端已在运行"
    else
        nohup uvicorn app.main:app --host 0.0.0.0 --port 8000 > ../data/logs/backend.log 2>&1 &
        echo $! > uvicorn.pid
        log_success "后端已启动 (PID: $(cat uvicorn.pid))"
    fi

    deactivate
    cd ..
}

start_frontend_local() {
    log_step "启动前端服务..."

    cd frontend

    if [ ! -d "node_modules" ]; then
        log_info "安装前端依赖..."
        npm install
    fi

    if [ -f "vite.pid" ] && kill -0 $(cat vite.pid) 2>/dev/null; then
        log_info "前端已在运行"
    else
        npm run dev > ../data/logs/frontend.log 2>&1 &
        echo $! > vite.pid
        log_success "前端已启动 (PID: $(cat vite.pid))"
    fi

    cd ..
}

start_local() {
    setup_mirrors
    setup_directories
    setup_env
    install_deps
    build_frontend
    start_redis_local
    start_backend_local
    start_frontend_local

    log_info "等待服务就绪..."
    for i in {1..30}; do
        if curl -s http://localhost:8000/api/health > /dev/null 2>&1; then
            log_success "后端服务已就绪"
            break
        fi
        sleep 1
    done
}

start_docker() {
    log_step "启动 Docker 服务..."

    docker-compose up -d redis
    sleep 2
    docker-compose up -d backend frontend

    log_success "Docker 服务启动中..."

    log_info "等待服务就绪..."
    for i in {1..30}; do
        if curl -s http://localhost:8000/api/health > /dev/null 2>&1; then
            log_success "后端服务已就绪"
            break
        fi
        sleep 1
    done
}

start_services() {
    if [ "$RUN_MODE" = "docker" ]; then
        start_docker
    else
        start_local
    fi
}

stop_local() {
    log_step "停止本地服务..."

    if [ -f "backend/uvicorn.pid" ]; then
        kill $(cat backend/uvicorn.pid) 2>/dev/null || true
        rm -f backend/uvicorn.pid
        log_success "后端已停止"
    fi

    if [ -f "frontend/vite.pid" ]; then
        kill $(cat frontend/vite.pid) 2>/dev/null || true
        rm -f frontend/vite.pid
        log_success "前端已停止"
    fi

    if pgrep -x "redis-server" > /dev/null; then
        pkill -x redis-server 2>/dev/null || true
        log_success "Redis 已停止"
    fi
}

cmd_start() {
    print_banner
    log_step "启动 Novel Reader (${RUN_MODE} 模式)..."

    cd "$PROJECT_DIR"

    check_env || exit 1
    start_services

    echo ""
    echo -e "${GREEN}═══════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}  项目已启动!${NC}"
    echo -e "${GREEN}═══════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "  ${GREEN}📖${NC} 前端页面:  http://localhost"
    echo -e "  ${GREEN}🔧${NC} API 文档:   http://localhost:8000/docs"
    echo -e "  ${GREEN}💓${NC} 健康检查:   http://localhost:8000/api/health"
    echo ""
    echo -e "${YELLOW}常用命令:${NC}"
    echo "  readweb status   - 查看状态"
    echo "  readweb logs     - 查看日志"
    echo "  readweb stop     - 停止服务"
    echo ""
}

cmd_stop() {
    log_step "停止服务..."
    if [ "$RUN_MODE" = "docker" ]; then
        docker-compose down 2>/dev/null || true
    else
        stop_local
    fi
    log_success "服务已停止"
}

cmd_restart() {
    cmd_stop
    sleep 1
    cmd_start
}

cmd_update() {
    print_banner
    log_step "更新项目..."

    cd "$PROJECT_DIR"

    if [ ! -d ".git" ]; then
        log_error "不是 git 仓库，无法更新"
        exit 1
    fi

    if ! git remote -v | grep -q "fetch"; then
        log_error "未配置远程仓库"
        exit 1
    fi

    log_step "保存当前状态..."
    ./readweb backup > /dev/null 2>&1 || true

    log_step "拉取最新代码..."
    if git pull origin main; then
        log_success "代码更新完成"
    else
        log_error "代码更新失败，可能有冲突"
        exit 1
    fi

    log_step "更新依赖..."
    install_deps
    build_frontend

    log_step "重启服务..."
    if [ "$RUN_MODE" = "docker" ]; then
        docker-compose up -d --force-recreate backend frontend
        docker-compose logs --tail=20 backend
    else
        stop_local
        sleep 1
        start_services
    fi

    echo ""
    log_success "项目更新完成!"
}

cmd_status() {
    log_step "服务状态"
    echo ""

    if [ "$RUN_MODE" = "docker" ]; then
        docker-compose ps
    else
        echo -e "${CYAN}[Local 模式]${NC}"
        echo ""

        if [ -f "backend/uvicorn.pid" ] && kill -0 $(cat backend/uvicorn.pid) 2>/dev/null; then
            log_success "后端服务: 运行中 (PID: $(cat backend/uvicorn.pid))"
        else
            log_error "后端服务: 未运行"
        fi

        if [ -f "frontend/vite.pid" ] && kill -0 $(cat frontend/vite.pid) 2>/dev/null; then
            log_success "前端服务: 运行中 (PID: $(cat frontend/vite.pid))"
        else
            log_error "前端服务: 未运行"
        fi

        if pgrep -x "redis-server" > /dev/null; then
            log_success "Redis: 运行中"
        else
            log_warning "Redis: 未运行"
        fi
    fi

    echo ""
    log_info "健康检查:"
    if curl -s http://localhost:8000/api/health > /dev/null 2>&1; then
        log_success "后端 API: 运行中"
    else
        log_error "后端 API: 未响应"
    fi

    if curl -s -o /dev/null -w "%{http_code}" http://localhost 2>/dev/null | grep -q "200\|301"; then
        log_success "前端页面: 运行中"
    else
        log_error "前端页面: 未响应"
    fi
}

cmd_logs() {
    local service="${1:-}"

    if [ "$RUN_MODE" = "docker" ]; then
        if [ -n "$service" ]; then
            log_info "查看 $service 日志 (Ctrl+C 退出)"
            docker-compose logs -f "$service"
        else
            log_info "查看所有日志 (Ctrl+C 退出)"
            docker-compose logs -f
        fi
    else
        if [ "$service" = "backend" ]; then
            log_info "查看后端日志 (Ctrl+C 退出)"
            tail -f data/logs/backend.log 2>/dev/null || echo "日志文件不存在"
        elif [ "$service" = "frontend" ]; then
            log_info "查看前端日志 (Ctrl+C 退出)"
            tail -f data/logs/frontend.log 2>/dev/null || echo "日志文件不存在"
        else
            if [ -f "data/logs/backend.log" ] && [ -f "data/logs/frontend.log" ]; then
                log_info "同时显示前后端日志 (Ctrl+C 退出)"
                echo ""
                tail -f data/logs/backend.log data/logs/frontend.log
            elif [ -f "data/logs/backend.log" ]; then
                tail -f data/logs/backend.log
            elif [ -f "data/logs/frontend.log" ]; then
                tail -f data/logs/frontend.log
            else
                log_warning "日志文件不存在"
            fi
        fi
    fi
}

cmd_deps() {
    setup_mirrors
    install_deps
    log_success "依赖安装完成"
}

cmd_mirror() {
    setup_mirrors
    log_success "镜像配置完成"
}

cmd_clean() {
    local all="${1:-}"

    log_warning "清理环境..."

    if [ "$all" = "--all" ]; then
        log_warning "将删除所有数据!"
        read -p "确认? (y/N): " confirm
        if [[ $confirm =~ ^[Yy]$ ]]; then
            cmd_stop
            rm -rf data books logs cache
            rm -rf frontend/node_modules backend/venv
            setup_directories
            log_success "环境已清理"
        else
            log_info "已取消"
        fi
    else
        rm -rf data/logs/* data/cache/* 2>/dev/null || true
        log_success "缓存已清理"
    fi
}

cmd_backup() {
    log_step "备份数据..."

    local backup_dir="data/backups"
    mkdir -p "$backup_dir"

    local timestamp=$(date +%Y%m%d_%H%M%S)
    local backup_file="$backup_dir/backup_$timestamp.tar.gz"

    tar -czf "$backup_file" \
        -C data \
        books db.json settings.json \
        --exclude='books/cache' \
        --exclude='books/tmp' \
        2>/dev/null || true

    log_success "备份已保存: $backup_file"

    cd "$backup_dir"
    ls -t backup_*.tar.gz 2>/dev/null | tail -n +6 | xargs rm -f 2>/dev/null || true
    cd - > /dev/null
}

cmd_restore() {
    local backup_file="$1"

    if [ -z "$backup_file" ]; then
        log_error "请指定备份文件"
        echo "用法: readweb restore <备份文件>"
        ls -la data/backups/backup_*.tar.gz 2>/dev/null | tail -5
        exit 1
    fi

    if [ ! -f "$backup_file" ]; then
        log_error "备份文件不存在: $backup_file"
        exit 1
    fi

    log_warning "将恢复备份: $backup_file"
    read -p "确认? (y/N): " confirm

    if [[ $confirm =~ ^[Yy]$ ]]; then
        cmd_stop
        tar -xzf "$backup_file" -C data
        log_success "备份已恢复"
        cmd_start
    else
        log_info "已取消"
    fi
}

main() {
    local command="${1:-}"
    local arg="${2:-}"

    if [ "$command" = "start" ] && [ "$arg" = "--docker" ]; then
        RUN_MODE="docker"
        command=""
    fi

    case "$command" in
        start) cmd_start ;;
        stop) cmd_stop ;;
        restart) cmd_restart ;;
        update) cmd_update ;;
        status) cmd_status ;;
        logs) cmd_logs "$arg" ;;
        deps) cmd_deps ;;
        mirror) cmd_mirror ;;
        clean) cmd_clean "$arg" ;;
        doctor) check_env ;;
        backup) cmd_backup ;;
        restore) cmd_restore "$arg" ;;
        version) show_version ;;
        help|--help|-h|"") show_help ;;
        *) log_error "未知命令: $command"; echo "运行 'readweb help' 查看帮助"; exit 1 ;;
    esac
}

main "$@"
