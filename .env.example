# ============================================
# Novel Reader 环境配置
# ============================================
# 复制此文件为 .env 并根据需要修改
# cp .env.example .env
#
# Docker 模式:  ./start.sh docker
# 本地模式:    ./start.sh local
# ============================================

# ---------- 数据库 ----------
DATABASE_URL=sqlite+aiosqlite:///data/novel.db

# ---------- Redis ----------
# Docker 模式使用容器内部地址
REDIS_URL=redis://redis:6379
# 本地模式使用 localhost（启动脚本会自动提示修改）
# REDIS_URL=redis://localhost:6379

# ---------- 安全 ----------
# JWT 密钥，生产环境务必修改！
# 可用 openssl rand -hex 32 生成
SECRET_KEY=your-secret-key-here-change-in-production

# ---------- 路径 ----------
BOOKS_DIR=./data/books
INDEX_DIR=./data/index

# ---------- 日志 ----------
LOG_LEVEL=INFO

# ---------- 调试 ----------
DEBUG=false
